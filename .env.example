# ============================================================================
# Google Sheets Configuration
# ============================================================================
# Service account credentials from Google Cloud Console
# 1. Create service account in GCP project
# 2. Generate private key (JSON) and save locally
# 3. Share Google Sheet with service account email

GOOGLE_SERVICE_ACCOUNT_EMAIL=codegate-service@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google Sheet ID (from URL: https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ============================================================================
# Internal Session & Auth Configuration
# ============================================================================
# Session secret for signing internal JWTs (jose)
# Generate: openssl rand -base64 32
# MUST be unique per environment (dev, preview, production)
# DO NOT expose in client-side bundle (no NEXT_PUBLIC_ prefix)
SESSION_SECRET=your-random-secret-here

# Optional: Session TTL in hours (default: 8)
# SESSION_TTL_HOURS=8

# ============================================================================
# External Auth Service
# ============================================================================
# Your existing authentication server endpoint
# This service must return: { id, name, email, role, role_id?, screening_type_id?, difficulty? }
# No trailing slash
EXTERNAL_AUTH_URL=https://your-auth-service.example.com

# ============================================================================
# Code Execution Service (Piston API)
# ============================================================================
# Option A: Self-hosted Piston (recommended for production)
#   Follow docs/setup/piston-deployment.md for VPS setup
#   CODE_EXECUTION_URL=http://your-piston-vps-ip:2000

# Option B: Public emkc.org (dev/testing only, rate-limited)
#   CODE_EXECUTION_URL=https://emkc.org
CODE_EXECUTION_URL=https://emkc.org

# ============================================================================
# Vercel Blob Storage (Optional)
# ============================================================================
# For storing large Excalidraw drawings (>100KB)
# Create token in Vercel Dashboard → Storage → Blob → Create Read-Write Token
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
